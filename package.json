    "build:prerender": "node scripts/generate-llms.mjs && vite build && (npx vite preview --port 4173 &) && (until curl -sf http://localhost:4173/ > /dev/null 2>&1; do sleep 1; done) && node scripts/prerender.mjs && pkill -f 'vite preview'",
