# =============================================
# Calk.kz — SPA на shared hosting (Apache)
# =============================================

# Кастомная 404 страница — важно поставить ДО mod_rewrite
ErrorDocument 404 /index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 301 редиректы старых slug-ов на актуальные (SEO-сохранение)
  RewriteRule ^calculator/mortgage/?$ /calculator/mortgage-specialized/ [R=301,L]
  RewriteRule ^calculator/notary-services/?$ /calculator/notary/ [R=301,L]
  RewriteRule ^calculator/gas-bill/?$ /calculator/gas/ [R=301,L]
  RewriteRule ^calculator/water-bill/?$ /calculator/water/ [R=301,L]
  RewriteRule ^__kk/calculator/mortgage/?$ /__kk/calculator/mortgage-specialized/ [R=301,L]
  RewriteRule ^__kk/calculator/notary-services/?$ /__kk/calculator/notary/ [R=301,L]
  RewriteRule ^__kk/calculator/gas-bill/?$ /__kk/calculator/gas/ [R=301,L]
  RewriteRule ^__kk/calculator/water-bill/?$ /__kk/calculator/water/ [R=301,L]
  RewriteRule ^embed/mortgage/?$ /embed/mortgage-specialized/ [R=301,L]
  RewriteRule ^embed/notary-services/?$ /embed/notary/ [R=301,L]
  RewriteRule ^embed/gas-bill/?$ /embed/gas/ [R=301,L]
  RewriteRule ^embed/water-bill/?$ /embed/water/ [R=301,L]

  # Не трогаем реально существующие файлы и папки
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Кэширование статики
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|svg|png|jpg|jpeg|webp|avif|ico|woff2|woff|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# GZIP сжатие
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
